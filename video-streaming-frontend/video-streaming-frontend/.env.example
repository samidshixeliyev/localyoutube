# ═══════════════════════════════════════════════════════════════
# ModTube frontend — dev server configuration
# Copy this file to .env before running `npm run dev`.
# ═══════════════════════════════════════════════════════════════

# Backend base URL the Vite dev server proxies /api, /hls,
# /thumbnails, /uploads and /ws to. Point this at wherever the
# Spring Boot backend is reachable (e.g. a WSL/Docker host).
VITE_BACKEND_URL=http://localhost:4000

# Port the Vite dev server itself listens on.
VITE_PORT=3000
