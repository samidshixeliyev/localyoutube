# ═══════════════════════════════════════════════════════════════
# ModTube — environment configuration
# Copy this file to .env and fill in your values before first run.
# ═══════════════════════════════════════════════════════════════

# ── Data directory ──────────────────────────────────────────────
# All persistent data (postgres, videos, grafana, prometheus) is
# stored under this single path on the host machine.
# Create it and give it full permissions before starting:
#   mkdir -p /opt/modtube/data && chmod 777 /opt/modtube/data
DATA_ROOT=/opt/modtube/data

# ── App network ─────────────────────────────────────────────────
# Public hostname or IP of this machine (used in OAuth2 redirect URIs).
APP_HOST=13.61.159.58
APP_PORT=4000

# ── IDP server (AO ID) ──────────────────────────────────────────
# Set IDP_HOST to the hostname or IP of the AO ID server.
# docker-compose builds all IDP URLs from this single variable:
#   IDP_BASE_URL          → https://<IDP_HOST>
#   IDP_JWKS_URI          → https://<IDP_HOST>/jwks
#   IDP_REDIRECT_URI      → http://<APP_HOST>:<APP_PORT>/
#   IDP_LOGOUT_REDIRECT_URI → http://<APP_HOST>:<APP_PORT>/logged_out
IDP_HOST=13.61.159.58
IDP_CLIENT_ID=EFxbQK-ekDX1OkWov51cjg
IDP_ISSUER=https://auth.ao.az
# Set to false if the IDP has a valid, trusted TLS certificate
IDP_SKIP_SSL=true

# ── JWT secret ──────────────────────────────────────────────────
# Minimum 32 characters. Change this before production use.
JWT_SECRET=please-change-this-secret-in-production-min-32-chars

# ── Admin seed account ──────────────────────────────────────────
# Created on first startup if it does not already exist.
ADMIN_EMAIL=admin@modtube.local
ADMIN_PASSWORD=changeme

# ── Rate limiting ────────────────────────────────────────────────
# Max requests per second per IP for general traffic
RATE_LIMIT_RPS=100
# Max requests per second per IP for video upload endpoint
RATE_LIMIT_UPLOAD_RPS=4

# ── Docker resource limits ───────────────────────────────────────
# Minimum recommended: 2 CPUs, 3 GB RAM
CPU_LIMIT=2.0
MEM_LIMIT=3G

# ── WebRTC (video meetings) ──────────────────────────────────────
# A coturn STUN/TURN server is BUNDLED inside the modtube image. Leave the two
# URLs blank and the app auto-generates them from APP_HOST (turn:APP_HOST:3478)
# so meetings work offline with no internet/Google STUN. Set them only to point
# clients at an EXTERNAL TURN server instead.
WEBRTC_ICE_SERVERS=
WEBRTC_TURN_URL=
# Credentials shared by the bundled coturn and the clients (both auto-match).
# Change them from the defaults for security.
WEBRTC_TURN_USERNAME=modtube
WEBRTC_TURN_CREDENTIAL=modtube-turn-secret
# Max participants per meeting room. Mesh + adaptive quality; 30 suits a fast LAN.
# Genuine large meetings still benefit from an SFU (see MEETINGS_SFU_PLAN.md).
WEBRTC_MAX_PARTICIPANTS=30

# ── Object storage (MinIO / S3-compatible) ───────────────────────
# Where transcoded HLS segments and thumbnails are stored and served from.
# MinIO runs as a SEPARATE stack:  docker compose -f docker-compose.minio.yml up -d
# The app reaches it via the host gateway by default.
# In PRODUCTION: point MINIO_ENDPOINT at your existing MinIO and set real creds.
MINIO_ENDPOINT=http://host.docker.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=modtube
# Optional — only for region-aware S3 backends (real AWS S3). Leave blank for MinIO.
MINIO_REGION=
