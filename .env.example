# ═══════════════════════════════════════════════════════════════
# ModTube — environment configuration
# Copy this file to .env and fill in your values before first run.
# ═══════════════════════════════════════════════════════════════

# ── Data directory ──────────────────────────────────────────────
# All persistent data (postgres, videos, grafana, prometheus) is
# stored under this single path on the host machine.
# Create it and give it full permissions before starting:
#   mkdir -p /opt/modtube/data && chmod 777 /opt/modtube/data
DATA_ROOT=/opt/modtube/data

# ── App network ─────────────────────────────────────────────────
# Public hostname or IP of this machine (used in OAuth2 redirect URIs).
APP_HOST=13.61.159.58
APP_PORT=4000
GRAFANA_PORT=3000

# ── IDP server (AO ID) ──────────────────────────────────────────
# Set IDP_HOST to the hostname or IP of the AO ID server.
# docker-compose builds all IDP URLs from this single variable:
#   IDP_BASE_URL          → https://<IDP_HOST>
#   IDP_JWKS_URI          → https://<IDP_HOST>/jwks
#   IDP_REDIRECT_URI      → http://<APP_HOST>:<APP_PORT>/
#   IDP_LOGOUT_REDIRECT_URI → http://<APP_HOST>:<APP_PORT>/logged_out
IDP_HOST=13.61.159.58
IDP_CLIENT_ID=EFxbQK-ekDX1OkWov51cjg
IDP_ISSUER=https://auth.ao.az
# Set to false if the IDP has a valid, trusted TLS certificate
IDP_SKIP_SSL=true

# ── JWT secret ──────────────────────────────────────────────────
# Minimum 32 characters. Change this before production use.
JWT_SECRET=please-change-this-secret-in-production-min-32-chars

# ── Admin seed account ──────────────────────────────────────────
# Created on first startup if it does not already exist.
ADMIN_EMAIL=admin@modtube.local
ADMIN_PASSWORD=changeme

# ── Grafana admin ───────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Rate limiting ────────────────────────────────────────────────
# Max requests per second per IP for general traffic
RATE_LIMIT_RPS=100
# Max requests per second per IP for video upload endpoint
RATE_LIMIT_UPLOAD_RPS=4

# ── Docker resource limits ───────────────────────────────────────
# Minimum recommended: 2 CPUs, 3 GB RAM
CPU_LIMIT=2.0
MEM_LIMIT=3G
