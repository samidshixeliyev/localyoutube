{
  "uid": "localtube-main",
  "title": "LocalTube — System & Application",
  "description": "Resource and application metrics for LocalTube video platform",
  "tags": ["localtube"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    { "id": 1, "type": "row", "title": "Overview", "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 2, "type": "stat", "title": "CPU Usage",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "CPU %" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 85 }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" }
    },

    {
      "id": 3, "type": "stat", "title": "Memory Usage",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "RAM %" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },

    {
      "id": 4, "type": "stat", "title": "Disk Usage",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100", "legendFormat": "Disk %" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },

    {
      "id": 5, "type": "stat", "title": "HTTP Req/s",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{job=\"localtube\"}[1m]))", "legendFormat": "req/s" }],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },

    {
      "id": 6, "type": "stat", "title": "Active Transcodings",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "localtube_active_transcodings", "legendFormat": "active" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "orange", "value": 2 }, { "color": "red", "value": 5 }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    {
      "id": 7, "type": "stat", "title": "Total Video Views",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "localtube_video_views_total", "legendFormat": "views" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },

    { "id": 10, "type": "row", "title": "System Resources", "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 11, "type": "timeseries", "title": "CPU Usage %",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "100 - (avg by(cpu)(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "Core {{cpu}}" },
        { "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "Average" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [{ "matcher": { "id": "byName", "options": "Average" }, "properties": [{ "id": "custom.lineWidth", "value": 3 }, { "id": "color", "value": { "fixedColor": "#5eead4", "mode": "fixed" } }] }]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 12, "type": "timeseries", "title": "Memory Usage",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemFree_bytes - node_memory_Buffers_bytes - node_memory_Cached_bytes", "legendFormat": "Used" },
        { "expr": "node_memory_Buffers_bytes + node_memory_Cached_bytes", "legendFormat": "Buffers/Cache" },
        { "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Available" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 13, "type": "timeseries", "title": "Network Traffic",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*\"}[2m])", "legendFormat": "↓ RX {{device}}" },
        { "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*\"}[2m])", "legendFormat": "↑ TX {{device}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 8 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 14, "type": "timeseries", "title": "Disk I/O",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total[2m])", "legendFormat": "Read {{device}}" },
        { "expr": "rate(node_disk_written_bytes_total[2m])", "legendFormat": "Write {{device}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 8 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    { "id": 20, "type": "row", "title": "JVM", "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 21, "type": "gauge", "title": "JVM Heap Usage",
      "gridPos": { "x": 0, "y": 23, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(jvm_memory_used_bytes{job=\"localtube\",area=\"heap\"}) / sum(jvm_memory_max_bytes{job=\"localtube\",area=\"heap\"}) * 100", "legendFormat": "Heap %" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true }
    },

    {
      "id": 22, "type": "timeseries", "title": "JVM Memory (Heap + Non-Heap)",
      "gridPos": { "x": 6, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{job=\"localtube\",area=\"heap\"})", "legendFormat": "Heap Used" },
        { "expr": "sum(jvm_memory_max_bytes{job=\"localtube\",area=\"heap\"})", "legendFormat": "Heap Max" },
        { "expr": "sum(jvm_memory_used_bytes{job=\"localtube\",area=\"nonheap\"})", "legendFormat": "Non-Heap Used" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 23, "type": "timeseries", "title": "JVM Threads",
      "gridPos": { "x": 18, "y": 23, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "jvm_threads_live_threads{job=\"localtube\"}", "legendFormat": "Live" },
        { "expr": "jvm_threads_daemon_threads{job=\"localtube\"}", "legendFormat": "Daemon" },
        { "expr": "jvm_threads_peak_threads{job=\"localtube\"}", "legendFormat": "Peak" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 8 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    { "id": 30, "type": "row", "title": "HTTP Traffic", "gridPos": { "x": 0, "y": 31, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 31, "type": "timeseries", "title": "HTTP Request Rate (by status)",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by(status) (rate(http_server_requests_seconds_count{job=\"localtube\"}[1m]))", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 8 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 32, "type": "timeseries", "title": "HTTP Response Time",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by(le)(rate(http_server_requests_seconds_bucket{job=\"localtube\"}[5m])))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, sum by(le)(rate(http_server_requests_seconds_bucket{job=\"localtube\"}[5m])))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, sum by(le)(rate(http_server_requests_seconds_bucket{job=\"localtube\"}[5m])))", "legendFormat": "P99" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5eead4", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },

    { "id": 40, "type": "row", "title": "Database Pool", "gridPos": { "x": 0, "y": 40, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 41, "type": "timeseries", "title": "HikariCP Connection Pool",
      "gridPos": { "x": 0, "y": 41, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "hikaricp_connections_active{job=\"localtube\"}", "legendFormat": "Active" },
        { "expr": "hikaricp_connections_idle{job=\"localtube\"}", "legendFormat": "Idle" },
        { "expr": "hikaricp_connections_pending{job=\"localtube\"}", "legendFormat": "Pending" },
        { "expr": "hikaricp_connections_max{job=\"localtube\"}", "legendFormat": "Max" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 8 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 42, "type": "timeseries", "title": "DB Connection Wait Time",
      "gridPos": { "x": 12, "y": 41, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(hikaricp_connections_acquire_seconds_bucket{job=\"localtube\"}[5m]))", "legendFormat": "Acquire P95" },
        { "expr": "histogram_quantile(0.50, rate(hikaricp_connections_acquire_seconds_bucket{job=\"localtube\"}[5m]))", "legendFormat": "Acquire P50" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 8 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    { "id": 50, "type": "row", "title": "Application Metrics", "gridPos": { "x": 0, "y": 49, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 51, "type": "timeseries", "title": "Upload Activity",
      "gridPos": { "x": 0, "y": 50, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(localtube_uploads_total[5m])", "legendFormat": "Attempts/s" },
        { "expr": "rate(localtube_uploads_success[5m])", "legendFormat": "Success/s" },
        { "expr": "rate(localtube_uploads_failed[5m])", "legendFormat": "Failed/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": [{ "matcher": { "id": "byName", "options": "Failed/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 52, "type": "timeseries", "title": "Video Views Rate",
      "gridPos": { "x": 12, "y": 50, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(localtube_video_views_total[5m])", "legendFormat": "Views/s" },
        { "expr": "localtube_video_views_total", "legendFormat": "Total Views" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 53, "type": "timeseries", "title": "Transcoding",
      "gridPos": { "x": 0, "y": 58, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "localtube_active_transcodings", "legendFormat": "Active" },
        { "expr": "rate(localtube_transcoding_success[5m])", "legendFormat": "Success/s" },
        { "expr": "rate(localtube_transcoding_failed[5m])", "legendFormat": "Failed/s" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": [{ "matcher": { "id": "byName", "options": "Failed/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }]
      },
      "options": { "tooltip": { "mode": "multi" } }
    },

    {
      "id": 54, "type": "timeseries", "title": "Transcoding Duration",
      "gridPos": { "x": 12, "y": 58, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(localtube_transcoding_duration_seconds_bucket[10m]))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.95, rate(localtube_transcoding_duration_seconds_bucket[10m]))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, rate(localtube_transcoding_duration_seconds_bucket[10m]))", "legendFormat": "P99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 6 } } },
      "options": { "tooltip": { "mode": "multi" } }
    },

    { "id": 60, "type": "row", "title": "Storage", "gridPos": { "x": 0, "y": 66, "w": 24, "h": 1 }, "collapsed": false },

    {
      "id": 61, "type": "bargauge", "title": "Storage Usage by Category",
      "gridPos": { "x": 0, "y": 67, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "localtube_disk_usage_bytes{type=\"uploads\"}", "legendFormat": "Uploads" },
        { "expr": "localtube_disk_usage_bytes{type=\"hls\"}", "legendFormat": "HLS Segments" },
        { "expr": "localtube_disk_usage_bytes{type=\"thumbnails\"}", "legendFormat": "Thumbnails" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null }, { "color": "yellow", "value": 5368709120 }, { "color": "red", "value": 21474836480 }
          ]},
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true }
    },

    {
      "id": 62, "type": "timeseries", "title": "Disk Free Space",
      "gridPos": { "x": 12, "y": 67, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}", "legendFormat": "Free" },
        { "expr": "node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}", "legendFormat": "Used" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": [{ "matcher": { "id": "byName", "options": "Free" }, "properties": [{ "id": "color", "value": { "fixedColor": "#5eead4", "mode": "fixed" } }] }]
      },
      "options": { "tooltip": { "mode": "multi" } }
    }

  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
